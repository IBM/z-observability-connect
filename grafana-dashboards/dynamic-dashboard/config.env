# ============================================
# Grafana Auto-Dashboard Configuration
# ============================================
# Edit these values according to your environment

# ============================================
# GRAFANA CONFIGURATION
# ============================================
# Grafana server URL (without trailing slash)
GRAFANA_URL=http://localhost:3000

# Note: Editor role does NOT have sufficient permissions for folder/dashboard creation
# Generate from: Grafana UI → Administration → Service Accounts → Create service account with Admin role
GRAFANA_API_KEY=your-grafana-api-key-here

# ============================================
# PROMETHEUS CONFIGURATION
# ============================================
# Prometheus server URL (without trailing slash)
PROM_URL=http://localhost:9090

# ============================================
# SCRIPT BEHAVIOR
# ============================================
# How often to check for new subsystems from prometheus(in seconds)
# How often to check for deleted subsystems from Grafana to update the cache(in seconds)
# Default: 10 seconds
CHECK_INTERVAL=10

# Maximum number of parallel operations
# Higher = faster but more load on Grafana API
# Default: 50
MAX_PARALLEL=50

# Root folder name in Grafana
# All dashboards will be created under this folder
# Default: zos-metrics
ROOT_FOLDER_NAME=zos-metrics

# ============================================
# DASHBOARD TEMPLATES
# ============================================
# Directory containing dashboard JSON templates
# Default: dashboards (relative to script location)
DASHBOARD_DIR=dashboards

# ============================================
# STATE MANAGEMENT
# ============================================
# File to track deployed dashboards
# Default: .grafana_deployed_state
STATE_FILE=.grafana_deployed_state

# ============================================
# LOGGING
# ============================================
# Log file location (optional)
# Leave empty to log to stderr only
# LOG_FILE=grafana-sync.log